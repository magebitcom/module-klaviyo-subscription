<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Customer\Controller\Account\CreatePost">
        <plugin name="subscribe_to_klaviyo_sms_after_account_create"
                type="Magebit\KlaviyoSubscription\Plugin\Controller\Account\CreatePostPlugin"/>
    </type>
    <type name="Magento\Newsletter\Controller\Manage\Save">
        <plugin name="SubscribeFromCustomerDashboard"
                type="Magebit\KlaviyoSubscription\Plugin\SubscribeFromCustomerDashboard"/>
    </type>
    <preference for="Klaviyo\Reclaim\Controller\Checkout\Cart"
                type="Magebit\KlaviyoSubscription\Controller\Checkout\Cart"/>
</config>
