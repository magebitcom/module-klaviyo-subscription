<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Klaviyo\Reclaim\KlaviyoV3Sdk\KlaviyoV3Api"
                type="Magebit\KlaviyoSubscription\KlaviyoV3Sdk\KlaviyoV3Api"/>
    <preference for="Klaviyo\Reclaim\Helper\Data"
                type="Magebit\KlaviyoSubscription\Helper\Data"/>
    <type name="Magento\Customer\Api\Data\CustomerExtensionFactory">
        <arguments>
            <argument name="data" xsi:type="array">
                <item name="is_sms_subscribed" xsi:type="object">Magento\Framework\Api\ExtensionAttribute\JoinProcessor</item>
            </argument>
        </arguments>
    </type>
    <preference for="Klaviyo\Reclaim\Observer\SaveOrderMarketingConsent"
                type="Magebit\KlaviyoSubscription\Observer\SaveOrderMarketingConsent"/>
    <preference for="Magebit\KlaviyoSubscription\Api\SmsPhoneValidationInterface"
                type="Magebit\KlaviyoSubscription\Model\SmsPhoneValidation"/>
    <type name="Magento\Quote\Api\CartRepositoryInterface">
        <plugin name="join_subscriptions_to_quote" type="Magebit\KlaviyoSubscription\Plugin\QuoteRepositoryPlugin" />
    </type>
    <type name="Magento\Customer\Api\CustomerRepositoryInterface">
        <plugin name="join_attributes" type="Magebit\KlaviyoSubscription\Plugin\CustomerRepositoryPlugin" />
    </type>
</config>
