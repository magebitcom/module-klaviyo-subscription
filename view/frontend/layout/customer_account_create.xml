<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <referenceBlock name="customer_form_register">
                <action method="setTemplate">
                    <argument name="template" xsi:type="string">Magebit_KlaviyoSubscription::form/register.phtml</argument>
                </action>
                <block class="Magento\Framework\View\Element\Template"
                       name="sms_subscription"
                       template="Magebit_KlaviyoSubscription::sms_subscription.phtml">
                    <block class="Magento\Framework\View\Element\Template"
                           name="phone-input"
                           template="Magebit_KlaviyoSubscription::phone-input.phtml"/>
                </block>
            </referenceBlock>
        </referenceContainer>
    </body>
</page>
